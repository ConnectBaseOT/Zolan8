rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: generations
    // Document ID: {generationId}
    // Fields:
    //   - sessionId: string (required)
    //   - prompt: string (required)
    //   - enhancedPrompt: string (required)
    //   - imageData: string (optional, base64)
    //   - createdAt: string (required)
    //
    // ===============================================================

    function isValidGeneration() {
      let data = request.resource.data;
      return data.keys().hasAll(['sessionId', 'prompt', 'enhancedPrompt', 'createdAt']) &&
             data.sessionId is string && data.sessionId.size() > 5 && data.sessionId.size() < 100 &&
             data.prompt is string && data.prompt.size() <= 2000 &&
             data.enhancedPrompt is string && data.enhancedPrompt.size() <= 4000 &&
             data.createdAt is string &&
             (!('imageData' in data) || data.imageData is string);
    }

    match /generations/{generationId} {
      // Allow read for anyone (relies on unguessable sessionId in the query)
      allow read: if true;
      allow create: if isValidGeneration();
      allow update: if false; // Generations are immutable
      allow delete: if false;
    }
  }
}
